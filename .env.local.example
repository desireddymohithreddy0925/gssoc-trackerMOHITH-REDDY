# ── Email (Gmail SMTP) ──────────────────────────────────────────
# Use a Gmail App Password (NOT your regular Gmail password):
# https://myaccount.google.com/apppasswords

SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password-here

# Who receives the notifications (can be same as SMTP_USER)
NOTIFY_EMAIL=your@gmail.com

# ── Optional: protect the /api/sync endpoint ────────────────────
SYNC_SECRET=change-this-to-a-random-secret


GITHUB_TOKEN=your-github-token-here
# ── GitHub Actions also needs these as repository secrets ────────
# Settings → Secrets → Actions → New repository secret:
#   SMTP_USER, SMTP_PASS, NOTIFY_EMAIL, SYNC_SECRET
